# Monyawn Backend Configuration
# Copy this to .env and fill in your values.
# All values are optional — the app is fully functional in local-only mode.

# ── Supabase (cloud sync) ────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── AI Intelligence ──────────────────────────────────────────────────────────
# Client-side key for local-first AI story generation.
# WARNING: keys set here are exposed in the browser bundle.
# Use a server-side proxy for production deployments.
VITE_OPENAI_API_KEY=your-openai-key
VITE_ANTHROPIC_API_KEY=your-anthropic-key
VITE_AI_PROVIDER=local   # local | openai | anthropic

# ── Feature Flags ────────────────────────────────────────────────────────────
VITE_FLAG_OPENAI=false         # Set to "true" to enable "Generate with AI" button
VITE_FLAG_SUPABASE_SYNC=true   # Set to "false" to disable cloud sync even when configured
VITE_FLAG_CREW_MODE=false      # Set to "true" to enable multi-user collaboration

# ── Observability ────────────────────────────────────────────────────────────
VITE_SENTRY_DSN=               # Sentry DSN for error tracking (leave blank to disable)
VITE_APP_VERSION=dev           # Injected at build time in CI

# ── Sentry Build-time (CI only, not prefixed with VITE_) ─────────────────────
# SENTRY_ORG=your-org
# SENTRY_PROJECT=monyawn
# SENTRY_AUTH_TOKEN=your-token
